# App
APP_NAME=SmartHelmetAPI
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smart_safety_helmet_db

# Redis
REDIS_URL=redis://localhost:6379

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Admin seed
FIRST_ADMIN_EMAIL=admin@smarthelmet.com
FIRST_ADMIN_PASSWORD=changeme

# Email (SMTP) — use a Gmail App Password, not your regular password
MAIL_USERNAME=jeandamourkubwimana0@gmail.com
MAIL_PASSWORD=enter-your-app-password-here
MAIL_FROM=jeandamourkubwimana0@gmail.com
MAIL_FROM_NAME=Smart Helmet System
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Frontend URL (used in reset link sent by email)
FRONTEND_URL=http://localhost:3000
